# Resume-Matcher backend LLM configuration
# Copied to resume-matcher/apps/backend/.env by setup

LLM_PROVIDER=openai_compatible
LLM_MODEL=smaller-qwens
LLM_API_BASE=http://deezr:4000/v1
LLM_API_KEY=

HOST=0.0.0.0
PORT=8000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
REQUEST_TIMEOUT_SECONDS=600
